#!/usr/bin/env bash
# SUMMARY: codex wrapper-harness adapter. install stages the codex binary into /installed-agent/codex; command emits OPENAI_API_KEY + model selection env consumed by harbor_adapters.codex:CodexAgent inside the harbor-runner.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "${SCRIPT_DIR}/common.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  codex install <agent-artifact-path>
  codex command  (reads profile JSON on stdin)
EOF
  return 2
}

cmd_install() {
  local artifact="${1:-}"
  if [[ -z "$artifact" ]]; then
    echo "codex install: missing <agent-artifact-path>" >&2
    return 2
  fi
  local binary="/installed-agent/codex"
  jq -cn \
    --arg src "$artifact" \
    --arg bin "$binary" \
    --arg cmd "install -m 0755 $artifact $binary" \
    --arg plugin "scripts.benchmark.harbor_adapters.codex:CodexAgent" \
    '{install_command:$cmd, artifact_source:$src, binary_path:$bin, harbor_plugin:$plugin}'
}

cmd_command() {
  local profile_json
  profile_json="$(benchmark_adapter_read_profile codex)"
  jq -cn --argjson p "${profile_json}" '
    $p
    | ($p.provider // {}) as $prov
    | ($p.sampling // {}) as $sampling
    | ($prov.api_key_env // "") as $keyenv
    | ($prov.model       // "gpt-5.4-mini") as $model
    | (
        {
          OPENAI_API_KEY: ("${" + $keyenv + "}"),
          FIZEAU_API_KEY: ("${" + $keyenv + "}"),
          FIZEAU_MODEL:   $model
        }
        + ( if ($sampling.reasoning // "") != "" then {FIZEAU_REASONING: $sampling.reasoning} else {} end )
      ) as $env
    | {
        command: (
          [
            "/installed-agent/codex","exec","--json","--ephemeral",
            "--skip-git-repo-check","--ignore-rules",
            "--dangerously-bypass-approvals-and-sandbox",
            "-m", $model
          ]
          + ( if ($sampling.reasoning // "") != "" then
                ["-c", ("reasoning.effort=" + $sampling.reasoning)]
              else [] end )
          + ["$HARBOR_INSTRUCTION"]
        ),
        env: $env,
        secret_env_keys: ["OPENAI_API_KEY","FIZEAU_API_KEY"]
      }
  '
}

main() {
  local sub="${1:-}"
  case "$sub" in
    install) shift; cmd_install "$@";;
    command) shift; cmd_command;;
    -h|--help|"") usage;;
    *) echo "codex: unknown subcommand: $sub" >&2; usage;;
  esac
}

main "$@"
