#!/usr/bin/env bash
# SUMMARY: harbor task-executor. Reads task-spec.json on stdin; resolves the local task path, then runs `docker run --rm ... fizeau-harbor-runner:latest run --yes --delete --path ... --agent-import-path ... --model ... --jobs-dir /output --job-name ...`; writes cell_dir/result.json or a missing_result stub. The docker socket is mounted so Harbor can spawn the task container.
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage:
  harbor  (reads task-spec.json on stdin)

task-spec.json fields (see scripts/benchmark/task-executors/CONTRACT.md):
  task_id         string  TerminalBench task id
  tasks_dir       string  host dir holding task definitions; bind-mounted at /tasks (ro)
  cell_dir        string  host dir for cell artifacts; bind-mounted at /output (rw)
  harbor_plugin   string  e.g. "scripts.benchmark.harbor_agent:FizeauAgent"
  image           string  default "fizeau-harbor-runner:latest"
  env             object  env to forward into the container
  secret_env_keys [str]   subset of env keys whose values are secrets (redacted in logs)
  extra_args      [str]   passthrough trailing args appended after Harbor's fixed args

The executor resolves <tasks_dir>/<task_id> (or <tasks_dir>/terminal-bench/<task_id>)
and runs Harbor with `--yes --delete --path <task_path> --agent-import-path ... --model ...`.
EOF
  return 2
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
fi

spec="$(cat)"
if [[ -z "$spec" ]]; then
  echo "harbor: empty task-spec on stdin" >&2
  exit 2
fi

task_id="$(jq -r '.task_id // ""' <<<"$spec")"
tasks_dir="$(jq -r '.tasks_dir // ""' <<<"$spec")"
cell_dir="$(jq -r '.cell_dir // ""' <<<"$spec")"
plugin="$(jq -r '.harbor_plugin // ""' <<<"$spec")"
image="$(jq -r '.image // "fizeau-harbor-runner:latest"' <<<"$spec")"
cell_id="$(basename "$cell_dir")"
model="$(jq -r '.env.FIZEAU_MODEL // ""' <<<"$spec")"
dry_run="${HARBOR_TASK_EXECUTOR_DRY_RUN:-0}"

if [[ -z "$task_id" || -z "$tasks_dir" || -z "$cell_dir" || -z "$plugin" ]]; then
  echo "harbor: task-spec missing one of {task_id, tasks_dir, cell_dir, harbor_plugin}" >&2
  exit 2
fi
if [[ -z "$model" && "${dry_run}" != "1" ]]; then
  echo "harbor: task-spec missing env.FIZEAU_MODEL" >&2
  exit 2
fi
if [[ ! -d "$tasks_dir" ]]; then
  echo "harbor: tasks_dir does not exist: $tasks_dir" >&2
  exit 2
fi
task_path="${tasks_dir}/${task_id}"
if [[ ! -d "${task_path}" ]]; then
  alt_task_path="${tasks_dir}/terminal-bench/${task_id}"
  if [[ -d "${alt_task_path}" ]]; then
    task_path="${alt_task_path}"
  elif [[ "${dry_run}" == "1" ]]; then
    task_path="${task_path}"
  else
    echo "harbor: task path does not exist: ${task_path}" >&2
    exit 2
  fi
fi
mkdir -p "$cell_dir"

declare -a docker_args=(
  run --rm
  -v /var/run/docker.sock:/var/run/docker.sock
  -v "$cell_dir:/output"
  -v "$tasks_dir:/tasks:ro"
)

declare -a harbor_args=(
  run
  --yes
  --delete
  --path "$task_path"
  --agent-import-path "$plugin"
  --model "$model"
)

while IFS=$'\t' read -r key val; do
  [[ -z "$key" ]] && continue
  docker_args+=(-e "$key=$val")
  harbor_args+=(--ae "$key=$val")
done < <(jq -r '(.env // {}) | to_entries[] | "\(.key)\t\(.value)"' <<<"$spec")

docker_args+=(
  --name "fizeau-harbor-${cell_id}"
  --label "fizeau-cell=${cell_id}"
  "$image"
  "${harbor_args[@]}"
)

while IFS= read -r arg; do
  [[ -z "$arg" ]] && continue
  docker_args+=("$arg")
done < <(jq -r '(.extra_args // []) | .[]' <<<"$spec")

result_path="$cell_dir/result.json"

if [[ "${HARBOR_TASK_EXECUTOR_DRY_RUN:-0}" == "1" ]]; then
  jq -n \
    --arg image "$image" \
    --arg task "$task_id" \
    --arg plugin "$plugin" \
    --argjson argv "$(printf '%s\n' "${docker_args[@]}" | jq -R . | jq -s .)" \
    '{dry_run:true, image:$image, task_id:$task, harbor_plugin:$plugin, docker_argv:$argv}' \
    >"$result_path"
  cat "$result_path"
  exit 0
fi

set +e
docker "${docker_args[@]}"
status=$?
set -e

if [[ ! -s "$result_path" ]]; then
  jq -n \
    --arg task "$task_id" \
    --arg image "$image" \
    --arg plugin "$plugin" \
    --argjson exit_code "$status" \
    '{task_id:$task, image:$image, harbor_plugin:$plugin, exit_code:$exit_code, status:"missing_result"}' \
    >"$result_path"
fi

exit "$status"
